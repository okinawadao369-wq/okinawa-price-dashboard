{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/fred",
      "destination": "/api/fred"
    },
    {
      "source": "/api/gdelt",
      "destination": "/api/gdelt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
